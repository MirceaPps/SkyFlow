pipeline {
agent any

```
stages {

    stage('Checkout') {
        steps {
            checkout scm
        }
    }

    stage('Build Docker Images') {
        steps {
            sh '''
            docker compose down
            docker compose up -d --build
            '''
        }
    }

    stage('Deploy') {
        steps {
            sh '''
            docker compose up -d
            '''
        }
    }

}
```

}
