pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'new-gitea',
                    url: 'https://gitea.dev.bodnarescu.ro/Mircea05/ProiectDev.git'
            }
       stage('Build Docker Images') {
    steps {
        dir('travel-devops') {
            sh 'docker compose build'
        }
    }
}

stage('Deploy') {
    steps {
        dir('travel-devops') {
            sh 'docker compose up -d'
        }
    }
}

    }
}
