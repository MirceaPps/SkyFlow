pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://gitea.dev.bodnarescu.ro/Mircea05/ProiectDev.git'
            }
        }

        stage('Build Docker Images') {
            steps {
                sh 'docker compose build'
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker compose up -d'
            }
        }
    }
}
